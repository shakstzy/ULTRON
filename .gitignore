# ULTRON .gitignore

# Run state, ephemeral
_shell/runs/
_shell/cursors/
_shell/skill-output/
_logs/
_graphify/runs/

# Credentials — NEVER commit
_credentials/
**/credentials/
**/.credentials/
**/secrets/
.env
.env.local
.env.*

# Local-only Claude Code overrides (may contain API keys)
.claude/settings.local.json

# OS noise
**/.DS_Store
**/Thumbs.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor
.idea/
.vscode/
*.swp

# Bot working stores — keep on disk, do not track in git
# (Chrome user profiles, node_modules, large outbound queue dirs)
**/.profile/
**/node_modules/
**/.cache/
**/.next/
**/dist/

# Outbound message queues — auto-managed by bots, churn too high for git
**/04-outbound/auto-sent/
**/04-outbound/expired/

# Bulk media scratch — clipping pipeline writes large video files outside git
# (declared per-workspace in clipping config)
**/_scratch/
**/scratch/

# Library workspace — full source content stays local (copyright posture)
# Wiki takeaways commit normally; raw full text does not.
workspaces/library/raw/books/
workspaces/library/raw/papers/
workspaces/library/raw/youtube/
workspaces/library/raw/reels/
workspaces/library/raw/articles/
