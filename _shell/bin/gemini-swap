#!/usr/bin/env node
// gemini-swap: manage multiple Gemini OAuth accounts
//
// Usage:
//   gemini-swap auth <email>   - run OAuth flow for <email>, force account chooser
//   gemini-swap use <email>    - activate cached creds for <email>
//   gemini-swap list           - list cached accounts
//   gemini-swap status         - show active account
//
// Stores per-account creds at ~/.gemini/accounts/<email>.json,
// active creds at ~/.gemini/oauth_creds.json (the file gemini reads).

const fs = require('fs');
const path = require('path');
const os = require('os');
const http = require('http');
const crypto = require('crypto');
const { exec, spawn } = require('child_process');
const https = require('https');
const querystring = require('querystring');

const HOME = os.homedir();
const GEMINI_DIR = path.join(HOME, '.gemini');
const ACCOUNTS_DIR = path.join(GEMINI_DIR, 'accounts');
const ACTIVE_CREDS = path.join(GEMINI_DIR, 'oauth_creds.json');
const ACCOUNTS_STATE = path.join(GEMINI_DIR, 'google_accounts.json');

// Extracted from gemini-cli bundle (chunk-2P3YD5SP.js).
// These are the public OAuth client credentials gemini-cli ships with.
const OAUTH_CLIENT_ID = '681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com';
const OAUTH_CLIENT_SECRET = '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';
const OAUTH_SCOPE = [
  'https://www.googleapis.com/auth/cloud-platform',
  'https://www.googleapis.com/auth/userinfo.email',
  'https://www.googleapis.com/auth/userinfo.profile',
  'openid',
].join(' ');

function ensureDirs() {
  if (!fs.existsSync(ACCOUNTS_DIR)) fs.mkdirSync(ACCOUNTS_DIR, { recursive: true });
}

function readJson(p) {
  if (!fs.existsSync(p)) return null;
  return JSON.parse(fs.readFileSync(p, 'utf8'));
}

function writeJson(p, obj, mode) {
  fs.writeFileSync(p, JSON.stringify(obj, null, 2));
  if (mode) fs.chmodSync(p, mode);
}

function accountFile(email) {
  return path.join(ACCOUNTS_DIR, `${email}.json`);
}

function listAccounts() {
  ensureDirs();
  return fs.readdirSync(ACCOUNTS_DIR)
    .filter(f => f.endsWith('.json') && !f.endsWith('-account.json'))
    .map(f => f.replace(/\.json$/, ''));
}

function activeEmail() {
  const state = readJson(ACCOUNTS_STATE);
  return state && state.active;
}

function getAvailablePort() {
  return new Promise((resolve, reject) => {
    const srv = http.createServer();
    srv.listen(0, '127.0.0.1', () => {
      const port = srv.address().port;
      srv.close(() => resolve(port));
    });
    srv.on('error', reject);
  });
}

function exchangeCode({ code, redirectUri, codeVerifier }) {
  const body = querystring.stringify({
    code,
    client_id: OAUTH_CLIENT_ID,
    client_secret: OAUTH_CLIENT_SECRET,
    redirect_uri: redirectUri,
    grant_type: 'authorization_code',
    code_verifier: codeVerifier,
  });
  return new Promise((resolve, reject) => {
    const req = https.request(
      {
        method: 'POST',
        hostname: 'oauth2.googleapis.com',
        path: '/token',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Content-Length': Buffer.byteLength(body),
        },
      },
      res => {
        let data = '';
        res.on('data', chunk => (data += chunk));
        res.on('end', () => {
          try {
            const parsed = JSON.parse(data);
            if (parsed.error) return reject(new Error(`token exchange failed: ${parsed.error} ${parsed.error_description || ''}`));
            resolve(parsed);
          } catch (e) { reject(e); }
        });
      }
    );
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

function decodeJwtPayload(jwt) {
  const parts = jwt.split('.');
  if (parts.length < 2) return {};
  const padded = parts[1] + '='.repeat((4 - parts[1].length % 4) % 4);
  return JSON.parse(Buffer.from(padded.replace(/-/g, '+').replace(/_/g, '/'), 'base64').toString('utf8'));
}

function pkce() {
  const verifier = crypto.randomBytes(32).toString('base64url');
  const challenge = crypto.createHash('sha256').update(verifier).digest('base64url');
  return { verifier, challenge };
}

async function authFlow(targetEmail) {
  ensureDirs();
  const port = await getAvailablePort();
  const redirectUri = `http://127.0.0.1:${port}/oauth2callback`;
  const state = crypto.randomBytes(32).toString('hex');
  const { verifier, challenge } = pkce();

  const params = {
    client_id: OAUTH_CLIENT_ID,
    redirect_uri: redirectUri,
    response_type: 'code',
    scope: OAUTH_SCOPE,
    access_type: 'offline',
    state,
    code_challenge: challenge,
    code_challenge_method: 'S256',
    prompt: 'select_account consent',
  };
  if (targetEmail) params.login_hint = targetEmail;
  const authUrl = 'https://accounts.google.com/o/oauth2/v2/auth?' + querystring.stringify(params);

  console.log(`\nAuth URL (will also auto-open):\n  ${authUrl}\n`);
  console.log(`Pick the ${targetEmail || 'desired'} account in the chooser.\n`);

  const tokens = await new Promise((resolve, reject) => {
    const server = http.createServer(async (req, res) => {
      try {
        if (!req.url.startsWith('/oauth2callback')) {
          res.writeHead(404); res.end(); return;
        }
        const qs = new URL(req.url, 'http://127.0.0.1').searchParams;
        if (qs.get('error')) {
          res.writeHead(200, { 'Content-Type': 'text/html' });
          res.end(`<h2>Auth error: ${qs.get('error')}</h2><p>You can close this tab.</p>`);
          return reject(new Error(`OAuth error: ${qs.get('error')} ${qs.get('error_description') || ''}`));
        }
        if (qs.get('state') !== state) {
          res.writeHead(400); res.end('state mismatch');
          return reject(new Error('OAuth state mismatch'));
        }
        const code = qs.get('code');
        if (!code) {
          res.writeHead(400); res.end('no code');
          return reject(new Error('No authorization code'));
        }
        try {
          const tokenResp = await exchangeCode({ code, redirectUri, codeVerifier: verifier });
          res.writeHead(200, { 'Content-Type': 'text/html' });
          res.end('<h2>Auth successful</h2><p>You can close this tab and return to the terminal.</p>');
          resolve(tokenResp);
        } catch (e) {
          res.writeHead(500); res.end('exchange failed');
          reject(e);
        }
      } finally {
        setTimeout(() => server.close(), 100);
      }
    });
    server.listen(port, '127.0.0.1', () => {
      exec(`open '${authUrl.replace(/'/g, "'\\''")}'`, () => {});
    });
    server.on('error', reject);
    setTimeout(() => reject(new Error('OAuth timeout (5 min)')), 5 * 60 * 1000);
  });

  // Verify which account was selected.
  const idPayload = tokens.id_token ? decodeJwtPayload(tokens.id_token) : {};
  const actualEmail = idPayload.email;
  if (!actualEmail) throw new Error('No email in id_token');
  if (targetEmail && actualEmail !== targetEmail) {
    console.warn(`\n⚠️  You picked ${actualEmail}, but requested ${targetEmail}. Saving as ${actualEmail}.`);
  }

  const creds = {
    access_token: tokens.access_token,
    refresh_token: tokens.refresh_token,
    scope: tokens.scope,
    token_type: tokens.token_type || 'Bearer',
    id_token: tokens.id_token,
    expiry_date: Date.now() + (tokens.expires_in * 1000),
  };

  const dest = accountFile(actualEmail);
  writeJson(dest, creds, 0o600);
  console.log(`Saved creds → ${dest}`);

  // Activate this account.
  activate(actualEmail);
  return actualEmail;
}

function activate(email) {
  const src = accountFile(email);
  if (!fs.existsSync(src)) {
    console.error(`No cached creds for ${email}. Run: gemini-swap auth ${email}`);
    process.exit(1);
  }
  // Stash current active before swap, so other windows don't lose it.
  const currentActive = activeEmail();
  if (currentActive && currentActive !== email && fs.existsSync(ACTIVE_CREDS)) {
    const stash = accountFile(currentActive);
    if (!fs.existsSync(stash)) {
      fs.copyFileSync(ACTIVE_CREDS, stash);
      fs.chmodSync(stash, 0o600);
    }
  }
  fs.copyFileSync(src, ACTIVE_CREDS);
  fs.chmodSync(ACTIVE_CREDS, 0o600);

  const known = new Set(listAccounts());
  const old = [...known].filter(e => e !== email).sort();
  writeJson(ACCOUNTS_STATE, { active: email, old });
  console.log(`Active gemini account: ${email}`);
}

function cmdList() {
  const active = activeEmail();
  const accounts = listAccounts();
  if (!accounts.length) { console.log('(no cached accounts)'); return; }
  for (const e of accounts.sort()) {
    console.log(`${e === active ? '* ' : '  '}${e}`);
  }
}

function cmdStatus() {
  const e = activeEmail();
  console.log(e ? `active: ${e}` : 'no active account');
}

async function main() {
  const [cmd, arg] = process.argv.slice(2);
  if (!cmd || cmd === 'help' || cmd === '-h' || cmd === '--help') {
    console.log('Usage:');
    console.log('  gemini-swap auth <email>   authorize a Google account, save creds');
    console.log('  gemini-swap use <email>    activate cached creds for <email>');
    console.log('  gemini-swap list           list cached accounts (* = active)');
    console.log('  gemini-swap status         show active account');
    return;
  }
  if (cmd === 'list') return cmdList();
  if (cmd === 'status') return cmdStatus();
  if (cmd === 'use') {
    if (!arg) { console.error('use: missing email'); process.exit(1); }
    return activate(arg);
  }
  if (cmd === 'auth') {
    return await authFlow(arg);
  }
  console.error(`unknown command: ${cmd}`);
  process.exit(1);
}

main().catch(e => { console.error(e.message || e); process.exit(1); });
