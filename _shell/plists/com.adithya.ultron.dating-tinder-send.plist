<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Drains approved queue. 8 fires/day with non-grid minute marks + 0-30min jitter on top.
     Effective fire window per slot: ~60min wide, irregular spacing. Defeats "obvious cron loop"
     pattern detection (visible to Tinder + to Adithya when he logs on).
     Hand-written (not generated by schedule skill) since the bot's schedule doesn't fit run-stage.sh. -->
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key><string>/Users/shakstzy</string>
		<key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
		<key>ULTRON_ROOT</key><string>/Users/shakstzy/ULTRON</string>
	</dict>
	<key>Label</key><string>com.adithya.ultron.dating-tinder-send</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-c</string>
		<string>flock -n /tmp/com.adithya.ultron.dating-tinder-send.lock bash -c 'cd /Users/shakstzy/ULTRON/workspaces/dating/bot &amp;&amp; sleep $((RANDOM % 1800)) &amp;&amp; node scripts/send.mjs'</string>
	</array>
	<key>RunAtLoad</key><false/>
	<key>StandardErrorPath</key><string>/Users/shakstzy/ULTRON/_logs/com.adithya.ultron.dating-tinder-send.err.log</string>
	<key>StandardOutPath</key><string>/Users/shakstzy/ULTRON/_logs/com.adithya.ultron.dating-tinder-send.out.log</string>
	<key>StartCalendarInterval</key>
	<array>
		<dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>23</integer></dict>
		<dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>18</integer></dict>
		<dict><key>Hour</key><integer>12</integer><key>Minute</key><integer>47</integer></dict>
		<dict><key>Hour</key><integer>14</integer><key>Minute</key><integer>11</integer></dict>
		<dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>39</integer></dict>
		<dict><key>Hour</key><integer>18</integer><key>Minute</key><integer>24</integer></dict>
		<dict><key>Hour</key><integer>20</integer><key>Minute</key><integer>46</integer></dict>
		<dict><key>Hour</key><integer>22</integer><key>Minute</key><integer>38</integer></dict>
	</array>
	<key>WorkingDirectory</key><string>/Users/shakstzy/ULTRON/workspaces/dating/bot</string>
</dict>
</plist>
