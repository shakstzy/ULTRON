		<string>-c</string>
		<string>flock -n /tmp/com.adithya.ultron.dating-tinder-swipe.lock /Users/shakstzy/ULTRON/_shell/bin/cron-runner.py com.adithya.ultron.dating-tinder-swipe -- bash -c 'cd /Users/shakstzy/ULTRON/workspaces/dating/bot &amp;&amp; sleep $((RANDOM % 1800)) &amp;&amp; node scripts/swipe.mjs'</string>
