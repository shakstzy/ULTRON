# Operational state — survives restarts but not git-tracked.
# Gemini adversarial review 2026-05-06: tracking run markers in git was an
# anti-pattern; execution state would pollute the repo on every batch.
state/

# Application packets (PDFs are heavy + may contain renter PII).
# Parsed-and-redacted markdown is appended to raw/leads/<slug>.md instead.
raw/applications/*/source.pdf
raw/applications/*/source.png

# Node deps — npm install reproduces.
playbooks/*/node_modules/

# OS noise
**/.DS_Store
